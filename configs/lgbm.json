{
  "name": "lgbm",
  "preprocessing": [
    {"type": "zero_to_nan"},
    {"type": "numeric_imputer"},
    {"type": "categorical_imputer"},
    {"type": "ordinal_encoder"}
  ],
  "features": [
    {"type": "redundant_dropper"},
    {"type": "pump_age"},
    {"type": "geo_cluster", "n_clusters": 20}
  ],
  "model": {
    "type": "lgbm",
    "n_estimators": 500,
    "max_depth": -1,
    "learning_rate": 0.05,
    "num_leaves": 63,
    "subsample": 0.8,
    "colsample_bytree": 0.8
  }
}
